# ==========================================
# Database Configuration (PostgreSQL + PostGIS)
# ==========================================
DATABASE_URL="postgresql://admin:secure_password@localhost:5432/pothole_intel?schema=public"

# ==========================================
# Backend API & Authentication
# ==========================================
API_PORT=4000
API_HOST=0.0.0.0
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# JWT Secrets (Generate strong random strings for production)
JWT_SECRET="super-secret-jwt-key-change-me-in-production"
JWT_EXPIRATION="24h"

# ==========================================
# Frontend Configuration
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Leaflet Map Tiles (Defaults to CartoDB Voyager or OpenStreetMap)
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png

# ==========================================
# AI Integration (Google Gemini)
# ==========================================
GEMINI_API_KEY=fake_placeholder_key

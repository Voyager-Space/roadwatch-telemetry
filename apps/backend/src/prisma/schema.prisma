generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis(version: "3.3")]
}

// ==========================================
// ENUMS (Mapped directly to Postgres ENUMs)
// ==========================================

enum RoleName {
  admin
  manager
  technician
  analyst
  viewer
}

enum PotholeStatus {
  detected
  verified
  assigned
  in_progress
  completed
  dismissed
  needs_recheck
  archived
}

enum TaskPriority {
  low
  medium
  high
  urgent
  critical
}

// ==========================================
// MODELS
// ==========================================

model User {
  id               String    @id @default(uuid())
  full_name        String
  email            String    @unique
  password_hash    String
  role_id          String
  avatar_url       String?
  phone_number     String?
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  last_login_at    DateTime?

  role             Role      @relation(fields: [role_id], references: [id])
  tasks            MaintenanceTask[]
  status_changes   PotholeStatusHistory[]
  audit_logs       AuditLog[]
  exports          Export[]

  @@map("users")
}

model Role {
  id               String    @id @default(uuid())
  name             RoleName  @unique
  description      String?
  permissions_json Json      @default("{}")
  users            User[]

  @@map("roles")
}

model Pothole {
  id               String    @id @default(uuid())
  pothole_code     String    @unique 
  cluster_id       String?
  title            String
  description      String?
  latitude         Float
  longitude        Float
  road_name        String?
  area_name        String?
  city             String?
  state            String?
  country          String?
  severity_score   Float     @default(0.0) 
  confidence_score Float     @default(0.0) 
  risk_score       Float     @default(0.0)
  current_status   PotholeStatus @default(detected)
  
  detected_at      DateTime  @default(now())
  verified_at      DateTime?
  assigned_at      DateTime?
  resolved_at      DateTime?
  archived_at      DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  is_archived      Boolean   @default(false)
  resolution_notes String?
  ai_summary_id    String?   @unique

  cluster          PotholeCluster? @relation(fields: [cluster_id], references: [id])
  ai_summary       AiSummary?      @relation(fields: [ai_summary_id], references: [id])
  events           PotholeEvent[]
  tasks            MaintenanceTask[]
  history          PotholeStatusHistory[]

  @@index([latitude, longitude])
  @@index([current_status])
  @@map("potholes")
}

model PotholeEvent {
  id               String    @id @default(uuid())
  pothole_id       String?
  device_id        String
  raw_packet_id    String    @unique
  latitude         Float
  longitude        Float
  acceleration_x   Float
  acceleration_y   Float
  acceleration_z   Float
  gyro_x           Float
  gyro_y           Float
  gyro_z           Float
  impact_force     Float
  speed_estimate   Float?
  gps_accuracy     Float?
  confidence_score Float
  event_timestamp  DateTime
  created_at       DateTime  @default(now())

  pothole          Pothole?  @relation(fields: [pothole_id], references: [id])
  raw_packet       RawPacket @relation(fields: [raw_packet_id], references: [id])

  @@map("pothole_events")
}

model RawPacket {
  id                   String    @id @default(uuid())
  packet_uuid          String    @unique
  raw_payload          Json
  checksum_valid       Boolean
  transmission_source  String
  received_at          DateTime  @default(now())
  decoded_successfully Boolean
  parser_version       String

  event                PotholeEvent?

  @@map("raw_packets")
}

model PotholeCluster {
  id                 String    @id @default(uuid())
  cluster_name       String
  centroid_latitude  Float
  centroid_longitude Float
  pothole_count      Int       @default(0)
  average_severity   Float     @default(0.0)
  cluster_risk_score Float     @default(0.0)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  potholes           Pothole[]

  @@map("pothole_clusters")
}

model MaintenanceTask {
  id                 String    @id @default(uuid())
  pothole_id         String
  assigned_user_id   String?
  task_status        PotholeStatus
  priority_level     TaskPriority
  task_notes         String?
  scheduled_date     DateTime?
  started_at         DateTime?
  completed_at       DateTime?
  verification_notes String?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  pothole            Pothole   @relation(fields: [pothole_id], references: [id])
  assignee           User?     @relation(fields: [assigned_user_id], references: [id])

  @@map("maintenance_tasks")
}

model PotholeStatusHistory {
  id                 String    @id @default(uuid())
  pothole_id         String
  old_status         PotholeStatus
  new_status         PotholeStatus
  changed_by_user_id String
  change_reason      String?
  changed_at         DateTime  @default(now())

  pothole            Pothole   @relation(fields: [pothole_id], references: [id])
  user               User      @relation(fields: [changed_by_user_id], references: [id])

  @@map("pothole_status_history")
}

model AiSummary {
  id                    String    @id @default(uuid())
  summary_text          String    @db.Text
  maintenance_note      String?   @db.Text
  repair_recommendation String?   @db.Text
  generated_model       String
  generated_at          DateTime  @default(now())
  cached_until          DateTime?

  pothole               Pothole?

  @@map("ai_summaries")
}

model HeatmapZone {
  id                     String    @id @default(uuid())
  zone_name              String
  center_latitude        Float
  center_longitude       Float
  risk_level             TaskPriority
  pothole_density        Float
  average_severity       Float
  active_pothole_count   Int
  resolved_pothole_count Int
  last_updated           DateTime  @default(now()) @updatedAt

  @@map("heatmap_zones")
}

model AuditLog {
  id            String   @id @default(uuid())
  user_id       String?
  action_type   String
  entity_type   String
  entity_id     String
  previous_data Json?
  new_data      Json?
  created_at    DateTime @default(now())

  user          User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model Export {
  id                   String   @id @default(uuid())
  export_type          String   
  generated_by_user_id String
  file_url             String
  created_at           DateTime @default(now())

  user                 User     @relation(fields: [generated_by_user_id], references: [id])

  @@map("exports")
}
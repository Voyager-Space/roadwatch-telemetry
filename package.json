{
  "name": "roadwatch",
  "version": "1.0.0",
  "private": true,
  "description": "Smart Pothole Detection & Road Condition Intelligence Platform",
  "author": "RoadWatch Engineering",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "turbo run db:generate --filter=@roadwatch/backend",
    "db:push": "turbo run db:push --filter=@roadwatch/backend",
    "db:migrate": "turbo run db:migrate --filter=@roadwatch/backend",
    "db:seed": "turbo run db:seed --filter=@roadwatch/backend",
    "db:studio": "turbo run db:studio --filter=@roadwatch/backend",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "docker:build": "docker-compose -f infrastructure/docker/docker-compose.yml build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "yarn@4.1.0"
}
